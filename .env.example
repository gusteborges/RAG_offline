# --- DATABASE CONFIGURATION ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smartdocs
# Use 'postgres_db' when running via Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres_db:5432/smartdocs

# --- OLLAMA (AI MODEL) CONFIGURATION ---
# Windows/Mac Docker Desktop: http://host.docker.internal:11434
# Linux/Homelab: http://<YOUR_HOST_IP>:11434 or http://172.17.0.1:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# --- SECURITY ---
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=yoursecretkeyhere
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- APP CONFIG ---
PROJECT_NAME="SmartDocs RAG"
DEBUG=True
