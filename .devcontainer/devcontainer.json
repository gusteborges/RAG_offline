{
    "name": "SmartDocs Dev Environment",
    
    "dockerComposeFile": [
        "../compose.yaml"
    ],

    "service": "server",
    "workspaceFolder": "/app",

    "remoteUser": "appuser",
    "containerUser": "appuser",

    // Sobrescreve o ENTRYPOINT para que o VS Code possa iniciar seu agente de dev
    "overrideCommand": true,

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "njpwerner.autodocstring",
                "tamasfe.even-better-toml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.languageServer": "Pylance",
                "editor.formatOnSave": true
            }
        }
    },
    
    // As migrações podem ser rodadas aqui no dev
    "postCreateCommand": "alembic upgrade head",
    "shutdownAction": "stopCompose"
}
